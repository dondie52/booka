# Supabase (required for DPO Pay integration)
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# DPO Pay (set as Supabase secrets, NOT here)
# Run: supabase secrets set DPO_COMPANY_TOKEN=your-dpo-company-token
# Run: supabase secrets set DPO_SERVICE_TYPE=your-service-type
#
# Test credentials (for development):
# DPO_COMPANY_TOKEN=9F416C11-127B-4DE2-AC7F-D5710E4C5E0A
# DPO_SERVICE_TYPE=3854
